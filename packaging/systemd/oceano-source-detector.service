[Unit]
Description=Oceano Source Detector (Physical media / None)
After=sound.target
Wants=sound.target

[Service]
Type=simple
ExecStart=/usr/local/bin/oceano-source-detector \
  --device-match "USB Microphone" \
  --output "/tmp/oceano-source.json" \
  --silence-threshold "0.025" \
  --debounce "10" \
  --vu-socket "/tmp/oceano-vu.sock" \
  --pcm-socket "/tmp/oceano-pcm.sock"
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
